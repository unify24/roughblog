---
import "../../styles/global.css";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{post.data.title}</title>
  </head>

  <body>
    <main class="container post-body">
      <a href="/blog" class="back-link">← Back to Blog</a>
      <h1>{post.data.title}</h1>
      <p class="post-date">{post.data.date}</p>
      <div class="post-content">
        <Content />
      </div>
    </main>
  </body>
</html>

<style>
  .back-link {
    display: inline-block;
    margin-bottom: 24px;
    color: var(--text-soft);
    text-decoration: none;
    font-size: 0.95rem;
  }
  .back-link:hover { color: var(--accent-dark); }
  .post-body h1 { font-size: 2rem; font-weight: 700; margin-bottom: 6px; }
  .post-date { color: var(--text-soft); font-size: 0.9rem; margin-bottom: 32px; }
  .post-content { line-height: 1.8; font-size: 1.05rem; }
  .post-content h2 { margin: 28px 0 12px; font-size: 1.4rem; }
  .post-content p  { margin-bottom: 16px; }
  .post-content ul, .post-content ol { padding-left: 24px; margin-bottom: 16px; }
  .post-content li { margin-bottom: 6px; }
  .post-content pre {
    background: #1e1e1e; color: #d4d4d4;
    padding: 20px; border-radius: 10px;
    overflow-x: auto; margin-bottom: 20px; font-size: 0.92rem;
  }
  .post-content code { background: var(--border); padding: 2px 6px; border-radius: 4px; font-size: 0.9em; }
  .post-content pre code { background: none; padding: 0; }
</style>
