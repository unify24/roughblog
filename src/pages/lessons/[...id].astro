---
import "../../styles/global.css";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const lessons = await getCollection("lessons");
  return lessons.map((lesson) => ({
    params: { id: lesson.id },
    props: { lesson },
  }));
}

const { lesson } = Astro.props;
const { Content } = await render(lesson);
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{lesson.data.title}</title>
  </head>

  <body>
    <main class="container lesson-body">
      <a href="/lessons" class="back-link">← Back to Lessons</a>

      {lesson.data.topic && (
        <span class="lesson-topic">{lesson.data.topic}</span>
      )}

      <h1>{lesson.data.title}</h1>
      <p class="lesson-date">{lesson.data.date}</p>

      <div class="lesson-content">
        <Content />
      </div>
    </main>
  </body>
</html>

<style>
  .back-link { display: inline-block; margin-bottom: 24px; color: var(--text-soft); text-decoration: none; font-size: 0.95rem; transition: color 0.2s; }
  .back-link:hover { color: var(--accent-dark); }
  .lesson-topic { display: inline-block; padding: 3px 12px; background: var(--accent); color: #fff; border-radius: 999px; font-size: 0.75rem; font-weight: 600; margin-bottom: 12px; }
  .lesson-body h1 { font-size: 2rem; font-weight: 700; margin-bottom: 6px; }
  .lesson-date { color: var(--text-soft); font-size: 0.9rem; margin-bottom: 32px; }
  .lesson-content { line-height: 1.8; font-size: 1.05rem; }
  .lesson-content h2 { margin: 28px 0 12px; font-size: 1.4rem; }
  .lesson-content h3 { margin: 20px 0 10px; font-size: 1.15rem; }
  .lesson-content p  { margin-bottom: 16px; }
  .lesson-content ul, .lesson-content ol { padding-left: 24px; margin-bottom: 16px; }
  .lesson-content li { margin-bottom: 6px; }
  .lesson-content pre { background: #1e1e1e; color: #d4d4d4; padding: 20px; border-radius: 10px; overflow-x: auto; margin-bottom: 20px; font-size: 0.92rem; }
  .lesson-content code { background: var(--border); padding: 2px 6px; border-radius: 4px; font-size: 0.9em; }
  .lesson-content pre code { background: none; padding: 0; }
  .lesson-content table { width: 100%; border-collapse: collapse; margin-bottom: 20px; }
  .lesson-content th, .lesson-content td { padding: 10px 14px; border: 1px solid var(--border); text-align: left; }
  .lesson-content th { background: var(--surface); font-weight: 600; }
</style>
