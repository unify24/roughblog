---
import "../../styles/global.css";
import { getCollection } from "astro:content";

const lessons = await getCollection("lessons");
lessons.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Lessons</title>
  </head>

  <body>
    <main class="container">
      <a href="/" class="back-link">← Home</a>
      <h1 class="page-title">Lessons</h1>
      <p class="page-subtitle">Click any lesson to start reading.</p>

      <div class="lesson-grid">
        {lessons.map((lesson) => (
          <a href={`/lessons/${lesson.id}`} class="lesson-card">
            {lesson.data.topic && (
              <span class="lesson-topic">{lesson.data.topic}</span>
            )}
            <h2>{lesson.data.title}</h2>
            <p>{lesson.data.description}</p>
            <small>{lesson.data.date}</small>
          </a>
        ))}
      </div>
    </main>
  </body>
</html>

<style>
  .back-link { display: inline-block; margin-bottom: 24px; color: var(--text-soft); text-decoration: none; font-size: 0.95rem; transition: color 0.2s; }
  .back-link:hover { color: var(--accent-dark); }
  .page-title { font-size: 2.2rem; font-weight: 700; margin-bottom: 8px; }
  .page-subtitle { color: var(--text-soft); margin-bottom: 36px; }
  .lesson-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 24px; }
  .lesson-card {
    display: flex; flex-direction: column; gap: 10px;
    padding: 28px; background: var(--surface); border: 1px solid var(--border);
    border-radius: 16px; text-decoration: none; color: var(--text);
    box-shadow: var(--shadow); transition: transform 0.2s, box-shadow 0.2s;
  }
  .lesson-card:hover { transform: translateY(-4px); box-shadow: 0 16px 40px rgba(0,0,0,0.1); }
  .lesson-topic { display: inline-block; padding: 3px 12px; background: var(--accent); color: #fff; border-radius: 999px; font-size: 0.75rem; font-weight: 600; width: fit-content; }
  .lesson-card h2 { font-size: 1.2rem; font-weight: 700; }
  .lesson-card p  { color: var(--text-soft); font-size: 0.95rem; flex: 1; }
  .lesson-card small { color: var(--text-soft); font-size: 0.8rem; }
</style>
